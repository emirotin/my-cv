{
  "name": "ai-cv",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write package.json .oxfmtrc.json tsconfig.json components.json vite.config.ts playwright.config.ts scripts 'src/**/*.ts' 'src/**/*.tsx' '!src/routeTree.gen.ts' 'tests/**/*.ts'",
    "format:check": "oxfmt --check package.json .oxfmtrc.json tsconfig.json components.json vite.config.ts playwright.config.ts scripts 'src/**/*.ts' 'src/**/*.tsx' '!src/routeTree.gen.ts' 'tests/**/*.ts'",
    "quality": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "precommit": "pnpm run format:check && pnpm run lint",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "test:e2e": "playwright test",
    "test:prerender": "node scripts/assert-prerender.mjs",
    "test": "pnpm run test:e2e && pnpm run test:prerender"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@mlc-ai/web-llm": "^0.2.84",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hast-util-to-string": "^3.0.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
